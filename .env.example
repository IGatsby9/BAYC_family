# Ethereum RPC endpoint (required)
# Use Alchemy, Infura, or any Ethereum mainnet RPC
# Examples:
#   https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   https://mainnet.infura.io/v3/YOUR_PROJECT_ID
#   https://eth.llamarpc.com (free, rate-limited)
ETH_RPC_URL=https://eth.llamarpc.com

# Optional: Etherscan API key for tx decoding fallback
# Free tier: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
